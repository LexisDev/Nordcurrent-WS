{
  "name": "nordcurrent-ws",
  "version": "1.0.0",
  "description": "Nordcurrent game server daemon",
  "scripts": {
    "start": "node dist/server.js",
    "cluster": "node dist/server-cluster.js",
    "compile": "tsc",
    "build": "tsc",
    "build-dev": "tsc & npm run build-docs",
    "test": "jest",
    "tsversion": "echo 'typescript: '  $(tsc --version); echo 'nodejs Version: '  $(node --version)",
    "lint": "eslint src/**/*.ts",
    "fix": "eslint --fix src/**/*.ts",
    "profile": "node --prof --log-timer-events dist/server.js",
    "watch": "tsc --watch",
    "tsr": "ts-node -e \"let[,m,f,...a]=process.argv;console.log(require(m)[f](...a))\"",
    "generate-docs": "npm run tsr ./src/utils/docs generateDocs",
    "build-docs": "npm run tsr ./src/utils/docs buildDocs"
  },
  "dependencies": {
    "amqplib": "^0.10.9",
    "dotenv": "^17.2.3",
    "ip": "^2.0.1",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.21",
    "mysql": "^2.18.1",
    "redis": "^4.7.1",
    "ws": "^8.18.3",
    "braces": "^3.0.3",
    "tar": "^7.5.2"
  },
  "devDependencies": {
    "@asyncapi/generator": "2.6.0",
    "@asyncapi/html-template": "^3.2.1",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@types/amqplib": "^0.10.8",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.21",
    "@types/mysql": "^2.15.27",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "jest-cli": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "socks": "^2.8.7",
    "puppeteer": "^24.31.0",
    "ajv": "^8.17.1",
    "eslint": {
      "ajv": "6.12.6"
    },
    "jsonpath-plus": "^10.3.0",
    "cross-spawn": "^7.0.6",
    "@babel/helpers": "^7.28.4",
    "@babel/runtime": "^7.28.4",
    "@eslint/plugin-kit": "^0.4.0"
  },
  "jest": {
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.+(ts|tsx|js)",
      "**/?(*.)+(spec|test).+(ts|tsx|js)"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "testTimeout": 70000
  }
}
